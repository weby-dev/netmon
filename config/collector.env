# /etc/netmon/collector.env
# Environment for the netmon-collector systemd service.

# Space-separated list of interfaces to monitor. On a Proxmox host:
#   - the physical uplink(s)      e.g. eno1, enp3s0
#   - the management bridge       e.g. vmbr0
#   - every VM tap interface      e.g. tap101i0 tap102i0   (for east-west)
#   - every container veth        e.g. veth101i0
# Tip: regenerate this list when VMs start/stop (see deploy/refresh-taps.sh).
NETMON_IFACES="vmbr0 eno1"

# XDP attach mode: skb (generic, works everywhere incl. tap/veth) | native | hw
NETMON_XDP_MODE="skb"

# ClickHouse connection.
NETMON_CLICKHOUSE_URL="http://127.0.0.1:8123"
NETMON_CLICKHOUSE_DB="netmon"
NETMON_CLICKHOUSE_USER="default"
NETMON_CLICKHOUSE_PASS=""

# Scrape / lifecycle tuning.
NETMON_INTERVAL="2"
NETMON_IDLE="30"

# Real-time stream (ntop-style live push straight from the collector, no DB in
# the path). Your application consumes the SSE endpoint http://<host>:<port>/live.
# This is a machine-consumable event stream only - there is no GUI.
NETMON_STREAM_ENABLE="1"
NETMON_STREAM_BIND="0.0.0.0"
NETMON_STREAM_PORT="8090"
NETMON_LIVE_INTERVAL="1"

# Security thresholds.
NETMON_DDOS_PPS="50000"        # inbound flood pps toward a victim
NETMON_DDOS_SYN="10000"        # inbound SYN/s toward a victim
NETMON_DDOS_OUT_PPS="20000"    # OUTBOUND flood pps from one internal host/VM
NETMON_DDOS_OUT_SYN="5000"     # OUTBOUND SYN/s from one internal host/VM
NETMON_ICMP_FLOOD="5000"       # ICMP pps toward a victim
NETMON_SCAN_PORTS="50"         # distinct dst ports -> port scan
NETMON_SCAN_HOSTS="50"         # distinct dst hosts -> host sweep
NETMON_BRUTEFORCE="40"         # conn attempts to one service port -> brute force
NETMON_DNS_RATE="300"          # DNS queries/window -> tunnelling/DGA
NETMON_LATERAL_HOSTS="10"      # internal hosts on admin ports -> lateral movement

# Real-time event webhook to the client's own endpoint. When the URL is set,
# high-severity events (attacks, scans, floods) are POSTed there as they happen;
# everything is still written to ClickHouse. install.sh fills these from --domain.
NETMON_EVENT_WEBHOOK_URL=""              # e.g. https://acme.com/api/webhook
NETMON_EVENT_WEBHOOK_TOKEN=""            # sent as X-Netmon-Token header
NETMON_EVENT_WEBHOOK_MIN_SEVERITY="high" # info|low|medium|high|critical

# Path to schema.sql (the collector applies it at startup).
NETMON_SCHEMA="/etc/netmon/schema.sql"
